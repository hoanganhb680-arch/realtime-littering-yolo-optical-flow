# Backend API
APP_HOST=127.0.0.1
APP_PORT=8000

# Detector input: file or ip_camera
DETECTOR_SOURCE_MODE=file
DETECTOR_VIDEO_FILE=video/di_bo_17.mp4

# IP camera settings, used when DETECTOR_SOURCE_MODE=ip_camera
DETECTOR_IP_CAM_HOST=192.168.0.103
DETECTOR_IP_CAM_PORT=8080
DETECTOR_IP_CAM_PROTOCOL=mjpeg
DETECTOR_IP_CAM_USER=
DETECTOR_IP_CAM_PASS=

# Local runtime paths
DETECTOR_MODEL_PATH=weights/best.pt
DETECTOR_OUTPUT_DIR=violations

# MinIO, optional evidence object storage
MINIO_URL=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=violations

